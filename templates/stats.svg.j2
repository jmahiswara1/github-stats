<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" fill="none" role="img" aria-label="{{ title }}">
  <title>{{ title }}</title>
  <style>
    {{ css_vars|safe }}
    .card {
      fill: var(--card-bg);
      stroke: var(--card-border);
      stroke-width: 1;
    }
    .title {
      fill: var(--accent);
      font: 600 16px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .label {
      fill: var(--text-secondary);
      font: 400 13px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .value {
      fill: var(--text-primary);
      font: 600 13px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .icon {
      fill: none;
      stroke: var(--text-secondary);
      stroke-width: 1.6;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .row { opacity: 0; animation: fadeUp 0.6s ease forwards; }
    {% for i in range(rows|length) %}
    .row-{{ i }} { animation-delay: {{ 0.05 + i * 0.06 }}s; }
    {% endfor %}
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .row { opacity: 1; animation: none; }
    }
  </style>

  <rect class="card" x="0.5" y="0.5" width="{{ width - 1 }}" height="{{ height - 1 }}" rx="10" ry="10"/>

  <text class="title" x="22" y="34">{{ title }}</text>

  {% set start_y = 70 %}
  {% set row_h = 28 %}
  {% for row in rows %}
  <g class="row row-{{ loop.index0 }}" transform="translate(22, {{ start_y + loop.index0 * row_h }})">
    <g class="icon" transform="translate(0, -10)">
      {{ row.icon|safe }}
    </g>
    <text class="label" x="26" y="0" dominant-baseline="middle">{{ row.label }}</text>
    <text class="value" x="{{ width - 44 }}" y="0" text-anchor="end" dominant-baseline="middle">{{ row.value }}</text>
  </g>
  {% endfor %}
</svg>
