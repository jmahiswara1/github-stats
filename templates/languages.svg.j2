<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" fill="none" role="img" aria-label="Languages Used">
  <title>Languages Used</title>
  <style>
    {{ css_vars|safe }}
    .card {
      fill: var(--card-bg);
      stroke: var(--card-border);
      stroke-width: 1;
    }
    .title {
      fill: var(--accent);
      font: 600 16px "Segoe UI", system-ui, sans-serif;
    }
    .subtitle {
      fill: var(--text-secondary);
      font: 400 11px "Segoe UI", system-ui, sans-serif;
    }
    .lang-name {
      fill: var(--text-primary);
      font: 600 13px "Segoe UI", system-ui, sans-serif;
    }
    .lang-pct {
      fill: var(--text-secondary);
      font: 400 13px "Segoe UI", system-ui, sans-serif;
    }
    .bar-track { fill: var(--card-border); }
  </style>

  <rect class="card" x="0.5" y="0.5" width="{{ width - 1 }}" height="{{ height - 1 }}" rx="10" ry="10"/>

  <text class="title" x="22" y="34">Languages Used</text>

  {% set bar_x = 22 %}
  {% set bar_w = width - 44 %}
  {% set bar_h = 10 %}
  {% set col_w = (width - 44) / 2 %}
  {% set row_h = 22 %}
  {% set section_h = 156 %}

  {% for section in sections %}
  {% set section_y = 56 + loop.index0 * section_h %}
  {% set bar_y = section_y + 16 %}
  {% set legend_y = section_y + 52 %}

  <text class="subtitle" x="{{ bar_x }}" y="{{ section_y }}">{{ section.label }}</text>

  <clipPath id="bar-clip-{{ loop.index0 }}">
    <rect x="{{ bar_x }}" y="{{ bar_y }}" width="{{ bar_w }}" height="{{ bar_h }}" rx="5" ry="5"/>
  </clipPath>
  <rect class="bar-track" x="{{ bar_x }}" y="{{ bar_y }}" width="{{ bar_w }}" height="{{ bar_h }}" rx="5" ry="5"/>
  <g clip-path="url(#bar-clip-{{ loop.index0 }})">
    {% set ns = namespace(offset=0) %}
    {% for item in section.langs %}
    <rect
          x="{{ bar_x + ns.offset }}"
          y="{{ bar_y }}"
          width="{{ (bar_w * item.pct / 100)|round(2) }}"
          height="{{ bar_h }}"
          fill="{{ item.color }}"/>
    {% set ns.offset = ns.offset + (bar_w * item.pct / 100) %}
    {% endfor %}
  </g>

  {% for item in section.langs %}
    {% set col = loop.index0 % 2 %}
    {% set row = loop.index0 // 2 %}
    <g transform="translate({{ 22 + col * col_w }}, {{ legend_y + row * row_h }})">
      <circle cx="6" cy="0" r="5" fill="{{ item.color }}"/>
      <text class="lang-name" x="18" y="0" dominant-baseline="middle">{{ item.name }}</text>
      <text class="lang-pct" x="{{ col_w - 14 }}" y="0" text-anchor="end" dominant-baseline="middle">{{ item.pct|percent }}</text>
    </g>
  {% endfor %}
  {% endfor %}
</svg>
