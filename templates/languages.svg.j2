<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}" fill="none" role="img" aria-label="{{ title }}">
  <title>{{ title }}</title>
  <style>
    {{ css_vars|safe }}
    .card {
      fill: var(--card-bg);
      stroke: var(--card-border);
      stroke-width: 1;
    }
    .title {
      fill: var(--accent);
      font: 600 16px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .subtitle {
      fill: var(--text-secondary);
      font: 400 11px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .lang-name {
      fill: var(--text-primary);
      font: 600 13px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .lang-pct {
      fill: var(--text-secondary);
      font: 400 13px -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
    .bar-track { fill: var(--card-border); }
    .bar-segment { transform-origin: left; transform: scaleX(0); animation: grow 0.7s ease forwards 0.15s; }
    .legend { opacity: 0; animation: fadeIn 0.5s ease forwards; }
    {% for i in range(items|length) %}
    .legend-{{ i }} { animation-delay: {{ 0.3 + i * 0.05 }}s; }
    {% endfor %}
    @keyframes grow { to { transform: scaleX(1); } }
    @keyframes fadeIn { to { opacity: 1; } }
    @media (prefers-reduced-motion: reduce) {
      .bar-segment { transform: scaleX(1); animation: none; }
      .legend { opacity: 1; animation: none; }
    }
  </style>

  <rect class="card" x="0.5" y="0.5" width="{{ width - 1 }}" height="{{ height - 1 }}" rx="10" ry="10"/>

  <text class="title" x="22" y="34">Languages Used</text>
  <text class="subtitle" x="{{ width - 22 }}" y="34" text-anchor="end">By {{ metric_label }}</text>

  {# Stacked horizontal bar #}
  {% set bar_x = 22 %}
  {% set bar_y = 56 %}
  {% set bar_w = width - 44 %}
  {% set bar_h = 10 %}
  <clipPath id="bar-clip">
    <rect x="{{ bar_x }}" y="{{ bar_y }}" width="{{ bar_w }}" height="{{ bar_h }}" rx="5" ry="5"/>
  </clipPath>
  <rect class="bar-track" x="{{ bar_x }}" y="{{ bar_y }}" width="{{ bar_w }}" height="{{ bar_h }}" rx="5" ry="5"/>
  <g clip-path="url(#bar-clip)">
    {% set ns = namespace(offset=0) %}
    {% for item in items %}
    <rect class="bar-segment"
          x="{{ bar_x + ns.offset }}"
          y="{{ bar_y }}"
          width="{{ (bar_w * item.pct / 100)|round(2) }}"
          height="{{ bar_h }}"
          fill="{{ item.color }}"/>
    {% set ns.offset = ns.offset + (bar_w * item.pct / 100) %}
    {% endfor %}
  </g>

  {# Legend grid: 2 columns #}
  {% set col_w = (width - 44) / 2 %}
  {% set legend_y = 92 %}
  {% set row_h = 22 %}
  {% for item in items %}
    {% set col = loop.index0 % 2 %}
    {% set row = loop.index0 // 2 %}
    <g class="legend legend-{{ loop.index0 }}" transform="translate({{ 22 + col * col_w }}, {{ legend_y + row * row_h }})">
      <circle cx="6" cy="0" r="5" fill="{{ item.color }}"/>
      <text class="lang-name" x="18" y="0" dominant-baseline="middle">{{ item.name }}</text>
      <text class="lang-pct" x="{{ col_w - 14 }}" y="0" text-anchor="end" dominant-baseline="middle">{{ item.pct|percent }}</text>
    </g>
  {% endfor %}
</svg>
